# =============================================================================
# AI-Researcher .gitignore
# =============================================================================

# --- Secrets & environment ---------------------------------------------------
.env
.env.*
!.env.template
**/.env
!**/.env.template

# --- Python ------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# --- IDE & OS ----------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# --- Application logs & temp (Web GUI / root) --------------------------------
logs/
tmp/
casestudy_results/

# --- Research Agent runtime --------------------------------------------------
# InnoFlow workplace, Docker mounts, agent cache, RAG vector stores
research_agent/workplace_*/
research_agent/workspace_*/
research_agent/cache/
research_agent/cache_*/
research_agent/log_*/
research_agent/code_db/
research_agent/paper_db/
research_agent/results/
research_agent/eval_data/
research_agent/evaluation_results/
research_agent/evaluation/**/data/
research_agent/*_tmp/
research_agent/*.log

# --- Paper Agent runtime -----------------------------------------------------
# Synced from research_agent; generated LaTeX/PDF outputs
paper_agent/paper_logs/
paper_agent/**/cache_*/
paper_agent/**/workplace/
paper_agent/**/target_sections/

# --- LaTeX build artifacts ---------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.synctex(busy)
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb
*.out

# --- ML / experiment outputs (runtime) ---------------------------------------
*.tar.gz
*.csv
*.pt
*.pth
*.ckpt
wandb/
mlruns/

# Scoped checkpoints (avoid ignoring benchmark_collection/checkpoints)
research_agent/**/checkpoints/
paper_agent/**/checkpoints/
examples/**/checkpoints/

# --- Playwright --------------------------------------------------------------
playwright-report/
test-results/
.playwright/
