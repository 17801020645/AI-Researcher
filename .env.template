
# =============================================================================
# AI-Researcher 环境变量模板
# 使用方式：cp .env.template .env 后填入真实值
# 详细说明见 doc/Start.md
# =============================================================================

# ================ container configuration ================
# 容器与执行环境相关配置（Research Agent 在 Docker 内运行代码与训练）

# workplace of the research agent
# 【作用】Research Agent 工作区的命名空间前缀，用于组织本地产出目录。
#         实际路径形如：research_agent/{DOCKER_WORKPLACE_NAME}/task_{INSTANCE_ID}_{MODEL}/
# 【配置建议】保持默认 workplace_paper 即可；多任务并行时可改为不同名称以避免目录冲突。
DOCKER_WORKPLACE_NAME=workplace_paper

# base image of the research agent
# 【作用】Docker 基础镜像，容器内运行 ML 代码、训练脚本及 tcp_server 命令执行服务。
# 【配置建议】推荐使用官方镜像 tjbtech1/airesearcher:v1（与 README 一致）。
#         部署前执行：docker pull tjbtech1/airesearcher:v1
#         注意：research_agent/constant.py 默认值为 tjbtech1/paperapp:latest，务必在此显式设置以免不一致。
BASE_IMAGES=tjbtech1/airesearcher:v1

# completion model name, configuration details see: https://docs.litellm.ai/docs/
# 【作用】主模型（LiteLLM 格式），供 ML Agent 等核心推理步骤使用，负责代码实现与实验执行。
# 【配置建议】选择推理与代码能力较强的模型；OpenRouter 示例：
#         openrouter/google/gemini-2.5-pro-preview-05-20
#         anthropic/claude-3-5-sonnet-20241022
#         模型名格式参见：https://docs.litellm.ai/docs/
COMPLETION_MODEL=openrouter/google/gemini-2.5-pro-preview-05-20

# cheep model name, configuration details see: https://docs.litellm.ai/docs/
# 【作用】辅助/廉价模型，供 Prepare、Survey、Plan、Judge、ExpAnalyser 等 Agent 使用。
# 【配置建议】可选用比 COMPLETION_MODEL 更便宜、速度更快的模型以降低成本，例如 flash/mini 系列。
#         若预算充足，可与 COMPLETION_MODEL 设为相同。
CHEEP_MODEL=openrouter/google/gemini-2.5-pro-preview-05-20

# specific gpu of the research agent, can be:
# '"device=0"' using the first gpu
# '"device=0,1"' using the first and second gpu
# '"all"' using all gpus
# None for no gpu
# 【作用】Docker 容器的 GPU 分配参数，对应 docker run --gpus 的值。
# 【配置建议】有 NVIDIA GPU 时：GPUS='"device=0"' 或 '"device=0,1"' 或 '"all"'
#         无 GPU / 仅 CPU：删除本行或留空（constant.py 中 GPUS 为 None 时不挂载 GPU）
#         需已安装 NVIDIA 驱动与 NVIDIA Container Toolkit。
GPUS='"device=0"'

# name of the container
# 【作用】Docker 容器名前缀；运行时实际名称为 {CONTAINER_NAME}_{INSTANCE_ID}_{MODEL}。
# 【配置建议】默认 paper_eval 即可；同一机器跑多个实例时，可改为不同前缀避免容器名冲突。
CONTAINER_NAME=paper_eval

# name of the workplace
# 【作用】挂载到容器内的工作目录名（-v 本地路径:/{WORKPLACE_NAME}）。
#         ML Agent 在容器内 /{WORKPLACE_NAME}/project/ 下编写与运行代码。
# 【配置建议】保持默认 workplace；一般无需修改。
WORKPLACE_NAME=workplace

# path of the cache
# 【作用】Agent 流水线磁盘缓存目录名前缀，由 main_ai_researcher 传入 CLI 参数。
#         实际缓存目录为 cache_{INSTANCE_ID}_{MODEL}（位于 task 目录下）。
# 【配置建议】保持默认 cache；用于 FlowModule 断点续跑，删除缓存将强制重新执行各 Agent 步骤。
CACHE_PATH=cache

# port of the research agent
# 【作用】宿主机端口，映射到容器内 tcp_server 的 8000 端口（-p {PORT}:8000）。
#         ML Agent 通过该端口在容器内执行 shell/Python 命令。
# 【配置建议】默认 7020；若端口被占用，改为 7021、12372 等未占用端口。
#         多实例并行时需为每个实例分配不同 PORT。
PORT=7020

# platform of the research agent
# 【作用】Docker 镜像平台架构（docker run --platform），用于跨架构拉取/运行镜像。
# 【配置建议】x86_64 Linux 主机：linux/amd64（默认）
#         Apple Silicon (M1/M2/M3)：建议 linux/amd64 并 docker pull --platform linux/amd64 ...
#         注意：需在 research_agent/constant.py 中定义 PLATFORM 变量，否则创建容器可能报错（见 doc/Start.md）。
PLATFORM=linux/amd64

# ================ llm configuration ================
# 大语言模型 API 与外部工具认证

# github ai token of the research agent
# 【作用】GitHub Personal Access Token，用于搜索/克隆参考代码仓库（Prepare Agent、code_search 等）。
# 【配置建议】在 GitHub Settings → Developer settings → Personal access tokens 创建；
#         至少授予 repo（私有库）与 public_repo 权限；无 token 时 GitHub 相关工具可能受限或失败。
GITHUB_AI_TOKEN=your_github_ai_token

# openrouter api key of the research agent
# 【作用】OpenRouter API 密钥；使用 openrouter/ 前缀模型时，LiteLLM 自动读取此变量。
# 【配置建议】在 https://openrouter.ai/keys 获取；COMPLETION_MODEL / CHEEP_MODEL 使用 OpenRouter 时必填。
OPENROUTER_API_KEY=your_openrouter_api_key

# openrouter api base url of the research agent
# 【作用】OpenRouter API 基础 URL。
# 【配置建议】一般保持默认 https://openrouter.ai/api/v1；使用代理或自建网关时改为对应地址。
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# ================ task configuration ================
# Benchmark 任务与运行模式（Web GUI / main_ai_researcher 从此读取）

# category of the research agent, based on: ./benchmark/final. Can be:
# diffu_flow
# gnn
# reasoning
# recommendation
# vq
# example: ./benchmark/final/vq
# 【作用】研究领域分类，对应 benchmark/final/{CATEGORY}/ 下的任务 JSON 与 metaprompt。
# 【配置建议】可选值：vq | gnn | recommendation | diffu_flow | reasoning
#         与 INSTANCE_ID 组合确定任务文件：benchmark/final/{CATEGORY}/{INSTANCE_ID}.json
CATEGORY=vq

# instance id of the research agent, example: ./benchmark/final/vq/one_layer_vq.json
# 【作用】Benchmark 实例 ID，不含 .json 后缀；定义参考论文、task1/task2 描述等任务内容。
# 【配置建议】从 benchmark/final/{CATEGORY}/ 目录选择，例如：one_layer_vq、rotation_vq、hgcl、gnn_difformer
#         完整列表见 doc/系统架构.md 或 benchmark/final/ 目录。
INSTANCE_ID=one_layer_vq

# task level of the research agent, can be:
# task1
# task2
# 【作用】读取 JSON 中哪个任务描述字段：task1（详细想法）或 task2（仅参考论文场景）。
# 【配置建议】Level 1「Detailed Idea Description」模式：task1
#         Level 2「Reference-Based Ideation」模式：通常仍读 task1 字段，但用户输入以参考论文为主；
#         评测对比 ground truth 时可切换 task2。
TASK_LEVEL=task1

# maximum iteration times of the research agent
# 【作用】Judge Agent 评估 ML 实现后，ML Agent 进行精炼改进的最大迭代轮数。
# 【配置建议】0 = 不进行 Judge↔ML 精炼循环（默认，耗时与 API 费用较低）
#         1~3 = 启用自动改进，质量可能提升但耗时与费用显著增加。
MAX_ITER_TIMES=0
